# Public API (place order, login, discover, portfolio)
PRED_BASE_URL=https://uat-frankfurt.pred.app

# Internal API (create API key only)
PRED_INTERNAL_URL=http://api-internal.uat-frankfurt.pred.app

# Local EIP-712 signing service (sign-create-proxy, sign-order)
SIG_SERVER_URL=http://localhost:5050

# HTTP server port for this service
PORT=5051

# Optional: delay before checking positions (ms)
POSITION_CHECK_DELAY_MS=2000

# Optional: axios request timeout (ms)
HTTP_TIMEOUT_MS=120000
