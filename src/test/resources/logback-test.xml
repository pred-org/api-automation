<?xml version="1.0" encoding="UTF-8"?>
<configuration>

  <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
    <encoder>
      <pattern>%d{HH:mm:ss} [%-5level] %logger{20} - %msg%n</pattern>
    </encoder>
  </appender>

  <!-- Suppress noisy third-party libs -->
  <logger name="org.apache.http" level="WARN"/>
  <logger name="io.restassured" level="WARN"/>
  <logger name="com.fasterxml.jackson" level="WARN"/>
  <logger name="org.testng" level="WARN"/>
  <logger name="io.qameta.allure" level="WARN"/>
  <logger name="org.apache.commons" level="WARN"/>

  <!-- Your own code: INFO so test progress and assertion failures are visible -->
  <logger name="com.pred.apitests" level="INFO"/>

  <!-- Root: WARN — anything not explicitly named above -->
  <root level="WARN">
    <appender-ref ref="CONSOLE"/>
  </root>

</configuration>
